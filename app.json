{
  "expo": {
    "name": "MotorIQ",
    "slug": "motoriq",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0B1020"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.motoriq.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B1020"
      },
      "package": "com.motoriq.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow MotorIQ to use your location for accident reporting."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow MotorIQ to access your photos for claim submissions.",
          "cameraPermission": "Allow MotorIQ to access your camera for accident documentation."
        }
      ]
    ]
  }
}
